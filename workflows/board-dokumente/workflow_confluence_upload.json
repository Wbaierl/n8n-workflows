      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst results = $input.item.json.results || [];\nconst d = $('Code: Ziel bauen (Aktiv/Config)').item.json;\nreturn { json: { ...d, confluence_subfolder_id: results[0]?.id || '' } };\n"
      },
