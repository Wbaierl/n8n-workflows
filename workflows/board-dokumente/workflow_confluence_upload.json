        "jsCode": "\nconst sd = $getWorkflowStaticData('global'); sd.results = sd.results || [];\nconst j = $input.item.json;\nsd.results.push({ notion_page_id: j.notion_page_id, confluence_id: '', result: 'no_target' });\nreturn $input.item;\n"
