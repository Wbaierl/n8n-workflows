    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst d = $input.item.json;\nconst shareUrl = d.onedrive_url || '';\nconst encoded = 'u!' + Buffer.from(shareUrl).toString('base64').replace(/=+$/,'').replace(/\\//g,'_').replace(/\\+/g,'-');\nreturn { json: { ...d, graph_download_url: `https://graph.microsoft.com/v1.0/shares/${encoded}/driveItem/content` } };\n"
      },
      "name": "Code: Graph Download-URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2700,
        120
      ],
      "id": "bdup2-0021"
    },
    {
      "parameters": {
        "url": "={{ $json.graph_download_url }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "microsoftOneDriveOAuth2Api",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "pdf_binary"
            }
          }
        }
      },
      "name": "HTTP: Datei von OneDrive laden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3360,
        120
      ],
      "credentials": {
        "microsoftOneDriveOAuth2Api": {
          "id": "9Ytar7NmBEFxr6Yz",
          "name": "Microsoft Drive account"
        }
      },
      "id": "bdup2-0022"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://blboardsolutions.atlassian.net/wiki/rest/api/content/' + $('Code: Graph Download-URL').item.json.confluence_subfolder_id + '/child/attachment?limit=100' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "options": {}
      },
      "name": "Confluence: Anhänge auflisten",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2920,
        120
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "OncAUjZtrqWedJug",
          "name": "Unnamed credential 2"
        }
      },
      "continueOnFail": true,
      "id": "bdup2-0023"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst d = $('Code: Graph Download-URL').item.json;\nconst subfolderId = d.confluence_subfolder_id || '';\n// Dateiname aus der OneDrive-URL ableiten (Confluence benennt den Anhang danach)\nconst filename = decodeURIComponent(((d.onedrive_url || '').split('?')[0].split('/').pop()) || 'dokument');\n// Existierenden Anhang gleichen Namens suchen\nconst atts = $input.item.json.results || [];\nconst existing = atts.find(a => a.title === filename);\nconst base = 'https://blboardsolutions.atlassian.net/wiki/rest/api/content/';\nconst upload_url = existing\n  ? base + subfolderId + '/child/attachment/' + existing.id + '/data'   // Update bestehender Anhang\n  : base + subfolderId + '/child/attachment';                          // Neu anlegen\nreturn { json: { ...d, upload_filename: filename, upload_url, _has_subfolder: !!subfolderId } };\n"
      },
      "name": "Code: Upload-Ziel bestimmen",
