    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst results = $input.first().json.results || [];\nif (results.length === 0) return [{ json: { _no_archiv: true } }];\nconst out = [];\nfor (const page of results) {\n  const idsRaw = page.properties['Confluence PageID']?.rich_text?.[0]?.plain_text || '';\n  const ids = idsRaw.split(',').map(s => s.trim()).filter(Boolean);\n  for (const cId of ids) out.push({ json: { notion_page_id: page.id, confluence_id: cId } });\n}\nreturn out.length ? out : [{ json: { _no_archiv: true } }];\n"
