    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst d = $('Code: Ziel bauen (Aktiv/Config)').item.json;\nconst body = JSON.stringify({\n  type: 'page', title: d.confluence_subfolder,\n  space: { key: d.confluence_space_key },\n  ancestors: [{ id: d.confluence_parent_page_id }],\n  body: { storage: { value: '<p>Dieser Ordner enthält alle ' + d.confluence_subfolder + ' für ' + d.source_name + '.</p>', representation: 'storage' } }\n});\nreturn { json: { ...d, create_body: body } };\n"
      },
