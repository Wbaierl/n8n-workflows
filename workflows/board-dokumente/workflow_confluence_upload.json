    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst up = $input.item.json;\nconst d = $('Code: Upload-Ziel bestimmen').item.json;\nlet attachmentId = '';\ntry { attachmentId = (up.results && up.results[0] && up.results[0].id) || up.id || ''; } catch(e){}\nconst uploadOk = !!attachmentId && !up.error && d._has_subfolder;\nconst sd = $getWorkflowStaticData('global'); sd.results = sd.results || [];\nsd.results.push({ notion_page_id: d.notion_page_id, confluence_id: d.confluence_subfolder_id || '',\n  result: uploadOk ? 'ok' : 'upload_failed' });\nconst labelName = (d.typ || 'Protokoll').toLowerCase() === 'agenda' ? 'agenda' : 'protokoll';\nreturn { json: {\n  _skip_label: !attachmentId,\n  label_name: labelName,\n  label_url: attachmentId ? ('https://blboardsolutions.atlassian.net/wiki/rest/api/content/' + attachmentId + '/label') : ''\n}};\n"
      },
      "name": "Code: Erfassen + Label",
