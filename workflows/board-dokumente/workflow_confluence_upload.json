    {
      "parameters": {
        "method": "POST",
        "url": "https://api.notion.com/v1/databases/619275ab2b7a4051a8f34c7519a7bc83/query",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "notionApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Notion-Version",
              "value": "2022-06-28"
            }
          ]
        },
        "options": {},
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "{\"filter\": {\"and\": [{\"property\": \"In Confluence anzeigen\", \"checkbox\": {\"equals\": true}}, {\"property\": \"ConfluenceSync\", \"checkbox\": {\"equals\": false}}, {\"property\": \"Status\", \"select\": {\"equals\": \"Freigegeben\"}}]}, \"page_size\": 50}"
      },
      "name": "Notion: Freigegebene Dokumente laden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -380,
        200
      ],
      "credentials": {
        "notionApi": {
          "id": "NnTc9kDS62fncKVA",
          "name": "Notion account"
        }
      },
      "id": "bdup2-0001"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst results = $input.first().json.results || [];\nif (results.length === 0) return [{ json: { _no_docs: true } }];\nreturn results.map(page => {\n  const p = page.properties;\n  return { json: {\n    notion_page_id: page.id,\n    title: p.Titel?.title?.[0]?.plain_text || 'Kein Titel',\n    typ: p.Typ?.select?.name || 'Protokoll',\n    onedrive_url: p['OneDrive URL']?.url || '',\n    gruppen_ids: (p['DB_Gruppen']?.relation || []).map(r => r.id),\n    kunden_ids: (p['DB Kunden']?.relation || []).map(r => r.id)\n  }};\n});\n"
      },
      "name": "Code: Dokumente aufbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        200
      ],
      "id": "bdup2-0002"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 3
          },
          "conditions": [
            {
              "id": "if:-hat-dokumente",
              "leftValue": "={{ $json._no_docs }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "name": "IF: Hat Dokumente",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        60,
        200
      ],
      "id": "bdup2-0003"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\n// Ergebnis-Sammlung fuer diesen Lauf zuruecksetzen\nconst sd = $getWorkflowStaticData('global');\nsd.results = [];\n\nconst out = [];\nfor (const item of $input.all()) {\n  const d = item.json;\n  if (d._no_docs) continue;\n  const targets = [];\n  for (const id of (d.gruppen_ids || [])) targets.push({ id, kind: 'gruppe' });\n  for (const id of (d.kunden_ids || []))  targets.push({ id, kind: 'kunde' });\n  if (targets.length === 0) {\n    out.push({ json: { notion_page_id: d.notion_page_id, title: d.title, typ: d.typ,\n      onedrive_url: d.onedrive_url, _no_target: true } });\n    continue;\n  }\n  for (const t of targets) out.push({ json: {\n    notion_page_id: d.notion_page_id, title: d.title, typ: d.typ, onedrive_url: d.onedrive_url,\n    target_id: t.id, target_kind: t.kind\n  }});\n}\nreturn out.length ? out : [{ json: { _no_docs: true } }];\n"
      },
      "name": "Code: Ziele expandieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        120
      ],
      "id": "bdup2-0004"
    },
    {
      "parameters": {
        "options": {}
      },
      "name": "Loop: Ziele",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        500,
        120
      ],
      "id": "bdup2-0005"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst sd = $getWorkflowStaticData('global');\nconst results = sd.results || [];\nconst byDoc = {};\nfor (const r of results) {\n  const id = r.notion_page_id; if (!id) continue;\n  (byDoc[id] = byDoc[id] || { ids: [], results: [] });\n  if (r.confluence_id) byDoc[id].ids.push(r.confluence_id);\n  byDoc[id].results.push(r.result);\n}\nsd.results = []; // aufraeumen\nconst out = [];\nfor (const [id, info] of Object.entries(byDoc)) {\n  const anyFail = info.results.includes('upload_failed');\n  const anyMissing = info.results.includes('config_missing');\n  const props = {};\n  if (info.ids.length) props['Confluence PageID'] = { rich_text: [{ text: { content: [...new Set(info.ids)].join(',') } }] };\n  if (anyFail || anyMissing) {\n    props['Status'] = { select: { name: 'Fehler' } };\n    props['Notizen'] = { rich_text: [{ text: { content: anyMissing\n      ? 'Confluence-Config (Space Key / PageID) bei mindestens einem aktiven Ziel fehlt.'\n      : 'Upload zu mindestens einem Ziel fehlgeschlagen.' } }] };\n  } else {\n    props['ConfluenceSync'] = { checkbox: true };\n  }\n  out.push({ json: { notion_page_id: id, body: JSON.stringify({ properties: props }) } });\n}\nreturn out.length ? out : [{ json: { _no_updates: true } }];\n"
      },
      "name": "Code: Finalisieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        520
      ],
      "id": "bdup2-0006"
    },
