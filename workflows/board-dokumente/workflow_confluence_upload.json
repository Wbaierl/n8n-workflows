    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst page = $input.item.json;\nconst ctx = $('Loop: Ziele').item.json;\nconst props = page.properties || {};\nconst getText = (p) => p?.rich_text?.[0]?.plain_text || p?.text?.[0]?.plain_text || '';\nconst isGruppe = ctx.target_kind === 'gruppe';\nconst active = isGruppe ? (props['Aktiv']?.checkbox === true) : (props['ActiveProject']?.checkbox === true);\nconst spaceKey = isGruppe ? getText(props['Confluence Space Key'])\n                          : (getText(props['ConfluenceSpaceKey']) || getText(props['Confluence Space Key']));\nconst parentId = getText(props['Confluence PageID']);\nconst sourceName = props.Name?.title?.[0]?.plain_text || '';\n// Ziel-Seite je Space-Typ: Gruppen -> '... PAB', Kunden -> '... Unternehmerboard'\nconst subfolder = isGruppe\n  ? (ctx.typ === 'Agenda' ? 'Agenda PAB' : 'Protokolle PAB')\n  : (ctx.typ === 'Agenda' ? 'Agenda Unternehmerboard' : 'Protokolle Unternehmerboard');\nconst configMissing = active && (!spaceKey || !parentId);\nconst deliver = active && !configMissing;\nreturn { json: {\n  notion_page_id: ctx.notion_page_id, title: ctx.title, typ: ctx.typ, onedrive_url: ctx.onedrive_url,\n  target_kind: ctx.target_kind, target_id: ctx.target_id, source_name: sourceName,\n  confluence_space_key: spaceKey, confluence_parent_page_id: parentId, confluence_subfolder: subfolder,\n  _active: active, _config_missing: configMissing, _deliver: deliver\n}};\n"
      },
      "name": "Code: Ziel bauen (Aktiv/Config)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1160,
        120
      ],
      "id": "bdup2-0012"
    },
    {
