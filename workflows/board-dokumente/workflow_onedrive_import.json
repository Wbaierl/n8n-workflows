    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const gruppenPage = $input.item.json;\nconst notionCreatedPageId = $('Notion: Eintrag erstellen').item.json.id;\nconst pdfItem = $('Loop: PDFs').item.json;\n\n// Extract DB Kunden relation IDs from the Gruppen page\nconst kundenRelation = gruppenPage.properties?.['DB Kunden']?.relation || [];\nconst kundenIds = kundenRelation.map(r => r.id).filter(Boolean);\n\nreturn {\n  json: {\n    notion_page_id: notionCreatedPageId,\n    kunden_ids: kundenIds,\n    has_kunden: kundenIds.length > 0,\n    pdf: pdfItem\n  }\n};"
      },
