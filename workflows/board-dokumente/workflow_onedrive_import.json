        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "notionApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Notion-Version", "value": "2022-06-28" }]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "{\"filter\":{\"and\":[{\"property\":\"ActiveProject\",\"checkbox\":{\"equals\":true}},{\"property\":\"URL Protokolle\",\"url\":{\"is_not_empty\":true}}]},\"page_size\":100}",
        "options": {}
      },
      "id": "bd000001-0000-0000-0000-000000000003",
      "name": "Notion: Kunden laden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [380, 420],
      "credentials": {
        "notionApi": {
          "id": "NnTc9kDS62fncKVA",
          "name": "Notion account"
        }
      }
