        "jsCode": "const item = $input.item.json;\nconst kundenRelations = item.kunden_ids.map(id => ({ id }));\n\nreturn {\n  json: {\n    _notion_page_id: item.notion_page_id,\n    body: JSON.stringify({\n      properties: {\n        'DB Kunden': { relation: kundenRelations },\n        'Dokumenttyp': { select: { name: 'Beides' } }\n      }\n    })\n  }\n};"
      },
