    {
      "parameters": {
        "mode": "append",
        "options": {}
      },
      "id": "bd000001-0000-0000-0000-000000000004",
      "name": "Merge: Gruppen + Kunden",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [600, 320]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst sources = [];\n\nfor (const item of items) {\n  const results = item.json.results || [];\n  for (const page of results) {\n    const props = page.properties;\n    // Distinguish: Gruppen have 'Aktiv', Kunden have 'ActiveProject'\n    const isGruppe = props['Aktiv'] !== undefined;\n    const name = props.Name?.title?.[0]?.plain_text || '';\n    const urlProtokolle = props['URL Protokolle']?.url || '';\n    const urlAgenda = props['URL Agenda']?.url || '';\n\n    if (urlProtokolle) {\n      sources.push({\n        json: {\n          source_type: isGruppe ? 'gruppe' : 'kunde',\n          source_id: page.id,\n          source_name: name,\n          onedrive_url: urlProtokolle\n        }\n      });\n    }\n    if (urlAgenda && urlAgenda !== urlProtokolle) {\n      sources.push({\n        json: {\n          source_type: isGruppe ? 'gruppe' : 'kunde',\n          source_id: page.id,\n          source_name: name,\n          onedrive_url: urlAgenda\n        }\n      });\n    }\n  }\n}\n\nreturn sources.length > 0 ? sources : [{json: {_no_sources: true}}];"
      },
      "id": "bd000001-0000-0000-0000-000000000005",
      "name": "Code: Quellen normalisieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [820, 320]
    },
    {
      "parameters": { "options": {} },
      "id": "bd000001-0000-0000-0000-000000000006",
      "name": "Loop: Quellen",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1040, 320]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\nif (item._no_sources) {\n  return { json: { _skip: true } };\n}\n\nconst shareUrl = item.onedrive_url;\nconst encoded = 'u!' + Buffer.from(shareUrl).toString('base64').replace(/=+$/, '').replace(/\\//g, '_').replace(/\\+/g, '-');\n\nreturn {\n  json: {\n    ...item,\n    encoded_url: encoded,\n    graph_url: `https://graph.microsoft.com/v1.0/shares/${encoded}/driveItem/children`\n  }\n};"
      },
      "id": "bd000001-0000-0000-0000-000000000007",
      "name": "Code: OneDrive URL encodieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1260, 420]
    },
    {
      "parameters": {
        "url": "={{ $json.graph_url }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "Microsoft Drive OAuth2 API",
        "options": {}
      },
      "id": "bd000001-0000-0000-0000-000000000008",
      "name": "HTTP: OneDrive Ordner lesen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1480, 420],
      "credentials": {
        "Microsoft Drive OAuth2 API": {
          "id": "74e2mFKEDMIJdHe4",
          "name": "Microsoft OneDrive OAuth2"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const source = $('Loop: Quellen').item.json;\nconst driveItems = $input.first().json.value || [];\n\nconst pdfs = driveItems\n  .filter(f => f.name && f.name.toLowerCase().endsWith('.pdf'))\n  .map(f => {\n    const filename = f.name;\n    const parts = filename.slice(0, -4).split('_');\n\n    let typ = 'Protokoll';\n    const prefix = parts[0].toUpperCase();\n    if (['AGD', 'AGENDA'].includes(prefix)) { typ = 'Agenda'; parts.shift(); }\n    else if (['PRO', 'PROTOKOLL'].includes(prefix)) { parts.shift(); }\n\n    let dateStr = null;\n    const re1 = /^\\d{4}-\\d{2}-\\d{2}$/;\n    const re2 = /^\\d{8}$/;\n    if (parts.length && re1.test(parts[0])) { dateStr = parts.shift(); }\n    else if (parts.length && re2.test(parts[0])) {\n      const d = parts.shift();\n      dateStr = `${d.slice(0,4)}-${d.slice(4,6)}-${d.slice(6,8)}`;\n    }\n\n    const title = parts.join(' ').trim() || filename;\n    const webUrl = f['webUrl'] || '';\n\n    return {\n      json: {\n        file_id: f.id,\n        filename,\n        title,\n        typ,\n        meeting_datum: dateStr,\n        web_url: webUrl,\n        size: f.size || 0,\n        source_type: source.source_type,\n        source_id: source.source_id,\n        source_name: source.source_name\n      }\n    };\n  });\n\nreturn pdfs.length > 0 ? pdfs : [{ json: { _no_pdfs: true } }];"
      },
      "id": "bd000001-0000-0000-0000-000000000009",
      "name": "Code: PDFs parsen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1700, 420]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "has-pdfs-check",
              "leftValue": "={{ $json._no_pdfs }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "notEquals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "bd000001-0000-0000-0000-000000000010",
