    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const fileId = $input.item.json.file_id;\nreturn {\n  json: {\n    ...$input.item.json,\n    _query_body: JSON.stringify({\n      filter: { property: 'OneDrive File ID', rich_text: { equals: fileId } },\n      page_size: 1\n    })\n  }\n};"
      },
