    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "exists-check",
              "leftValue": "={{ $json.results.length }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "bd000001-0000-0000-0000-000000000013",
      "name": "IF: Neu (nicht vorhanden)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [2580, 320]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const pdf = $('Loop: PDFs').item.json;\n\nconst properties = {\n  'Titel': { title: [{ text: { content: pdf.title } }] },\n  'Typ': { select: { name: pdf.typ } },\n  'Dokumenttyp': { select: { name: pdf.source_type === 'gruppe' ? 'Board' : 'Individuell' } },\n  'OneDrive URL': { url: pdf.web_url || null },\n  'OneDrive File ID': { rich_text: [{ text: { content: pdf.file_id } }] },\n  'Status': { select: { name: 'Entwurf' } },\n  'Quelle Board': { rich_text: [{ text: { content: pdf.source_name } }] },\n  'In Confluence anzeigen': { checkbox: false },\n  'ConfluenceSync': { checkbox: false }\n};\n\nif (pdf.meeting_datum) {\n  properties['Meeting Datum'] = { date: { start: pdf.meeting_datum } };\n}\n\nif (pdf.source_type === 'gruppe') {\n  properties['DB_Gruppen'] = { relation: [{ id: pdf.source_id }] };\n} else {\n  properties['DB Kunden'] = { relation: [{ id: pdf.source_id }] };\n}\n\nreturn {\n  json: {\n    _pdf: pdf,\n    body: JSON.stringify({\n      parent: { database_id: '619275ab2b7a4051a8f34c7519a7bc83' },\n      properties\n    })\n  }\n};"
      },
