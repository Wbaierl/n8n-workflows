        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 600,\n  \"temperature\": 0.1,\n  \"system\": {{ JSON.stringify(\"Du analysierst eingehende Kunden-Emails praezise und strukturiert.\\nAntworte ausschliesslich als valides JSON ohne Markdown-Formatierung.\\n\\nAnalysiere die Email nach diesen Dimensionen:\\n\\n{\\n  \\\"tonalitaet\\\": \\\"neutral|freundlich|formell|frustriert|aggressiv|verzweifelt\\\",\\n  \\\"dringlichkeit\\\": \\\"niedrig|mittel|hoch|sehr_hoch\\\",\\n  \\\"beziehung\\\": \\\"bestehender_kunde|neukunde|unbekannt\\\",\\n  \\\"stimmung\\\": \\\"zufrieden|neutral|enttaeuscht|veraergert|wuetend\\\",\\n  \\\"empathie_level\\\": \\\"niedrig|mittel|hoch\\\",\\n  \\\"hauptanliegen\\\": \\\"[praezise Zusammenfassung in einem Satz: Was will der Absender wirklich?]\\\",\\n  \\\"antwort_struktur\\\": \\\"fliesstext|bullet_points|gemischt\\\",\\n  \\\"eskalation\\\": false,\\n  \\\"eskalation_grund\\\": \\\"\\\",\\n  \\\"empfohlene_laenge\\\": 100,\\n  \\\"keywords\\\": [\\\"Begriff1\\\", \\\"Begriff2\\\"]\\n}\\n\\nEskalation = true bei: expliziten rechtlichen Drohungen, Beleidigungen, Datenschutzverletzungen oder Themen die Anwaltskosten oder Behoerden erwaehnen.\") }},\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\"Analysiere diese Email:\\nAbsender: \" + $json.from_email + \"\\nName: \" + $json.from_name + \"\\nBetreff: \" + $json.subject + \"\\nInhalt:\\n\" + $json.body) }}\n    }\n  ]\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "ea000007-0000-0000-0000-000000000007",
      "name": "Claude Analyse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1340, 500],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000,
      "credentials": {
        "anthropicApi": {
          "id": "iCMaqkiVfMfgXWXJ",
          "name": "Anthropic account 6"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Claude-Antwort parsen und Analyse-JSON extrahieren\nconst response = $input.item.json;\nconst text = response.content[0].text;\n\n// JSON aus Claude-Antwort extrahieren (ggf. Markdown-Code-Blocks entfernen)\nconst jsonMatch = text.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) {\n  throw new Error('Claude hat kein valides JSON zurueckgegeben. Antwort: ' + text.substring(0, 300));\n}\n\nlet analyse;\ntry {\n  analyse = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  throw new Error('JSON-Parse-Fehler: ' + e.message + ' | Text: ' + text.substring(0, 200));\n}\n\n// Email- und HubSpot-Daten aus vorherigem Node holen\nconst emailData = $('Daten zusammenführen').first().json;\n\nreturn [{\n  json: {\n    // Analyse-Felder\n    tonalitaet: analyse.tonalitaet || 'neutral',\n    dringlichkeit: analyse.dringlichkeit || 'mittel',\n    beziehung: analyse.beziehung || 'bestehender_kunde',\n    stimmung: analyse.stimmung || 'neutral',\n    empathie_level: analyse.empathie_level || 'mittel',\n    hauptanliegen: analyse.hauptanliegen || 'Kein Anliegen erkannt',\n    antwort_struktur: analyse.antwort_struktur || 'fliesstext',\n    eskalation: analyse.eskalation === true,\n    eskalation_grund: analyse.eskalation_grund || '',\n    empfohlene_laenge: analyse.empfohlene_laenge || 100,\n    keywords: Array.isArray(analyse.keywords) ? analyse.keywords : [],\n    // Email-Daten durchreichen\n    from_email: emailData.from_email,\n    from_name: emailData.from_name,\n    subject: emailData.subject,\n    body: emailData.body,\n    message_id: emailData.message_id,\n    received_at: emailData.received_at,\n    // HubSpot-Daten durchreichen\n    hubspot_name: emailData.hubspot_name,\n    hubspot_id: emailData.hubspot_id,\n    hubspot_company: emailData.hubspot_company\n  }\n}];"
      },
