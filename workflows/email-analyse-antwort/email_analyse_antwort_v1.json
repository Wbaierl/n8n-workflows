    {
      "parameters": {
        "toRecipients": "wolfgang.baierl@blboardsolutions.de",
        "subject": "=⚠️ Manuelle Review erforderlich: {{ $json.subject }}",
        "bodyContent": "=ESKALATION – Diese Email erfordert manuelle Bearbeitung!\n\nGrund: {{ $json.eskalation_grund }}\n\nAbsender: {{ $json.from_name }} <{{ $json.from_email }}>\nBetreff: {{ $json.subject }}\nTon: {{ $json.tonalitaet }} | Stimmung: {{ $json.stimmung }} | Dringlichkeit: {{ $json.dringlichkeit }}\nHauptanliegen: {{ $json.hauptanliegen }}\nKunde: {{ $json.hubspot_name }} ({{ $json.hubspot_company || 'Unbekannt' }})\n\nKeine automatische Antwort wurde erstellt.\nBitte diese Email sorgfältig manuell bearbeiten.",
        "additionalFields": {}
      },
      "id": "ea000010-0000-0000-0000-000000000010",
      "name": "Eskalation Email",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [2000, 300],
