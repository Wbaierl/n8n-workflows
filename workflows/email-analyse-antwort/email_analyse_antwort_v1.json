    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "anthropicApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1200,\n  \"temperature\": 0.7,\n  \"system\": {{ JSON.stringify(\"Du bist ein professioneller Email-Assistent und schreibst Antworten im persoenlichen Stil des Nutzers.\\n\\n=== SCHREIBSTIL-PROFIL DES NUTZERS ===\\n[HIER EINSETZEN – Beschreibe deinen Stil, z.B.:]\\nDirekt und auf den Punkt, keine langen Einleitungen.\\nVerwendet 'Sie'-Anrede, aber mit warmem Ton.\\nSchreibt aktive Saetze, vermeidet Passiv.\\nNutzt kurze Absaetze fuer bessere Lesbarkeit.\\nKeine uebertriebenen Floskeln.\\nTypische Signatur: 'Beste Gruesse, [Dein Name]'\\n\\n=== STIL-BEISPIELE (echte Emails des Nutzers) ===\\n[BEISPIEL 1 – HIER EINSETZEN]\\n\\n[BEISPIEL 2 – HIER EINSETZEN]\\n\\n[BEISPIEL 3 – HIER EINSETZEN]\\n\\n=== ANTWORT-STRATEGIE (basierend auf Analyse) ===\\n- stimmung=veraergert/wuetend: Sofortige Empathie, Verantwortung uebernehmen, keine Ausreden\\n- stimmung=enttaeuscht: Verstaendnis zeigen, Loesungsweg aufzeigen\\n- stimmung=neutral/zufrieden: Professionell und effizient\\n- antwort_struktur=bullet_points: Nutze Aufzaehlungspunkte\\n- antwort_struktur=fliesstext: Zusammenhaengende Absaetze\\n- Erstelle NUR den Email-Body, keine Betreffzeile\\n- Beginne direkt mit der Anrede\\n- Nutze den echten Kundennamen aus den Daten, keine Platzhalter wie [Name]\\n- Empfohlene Laenge ist ein Richtwert (+/-10%)\\n- Der Text ist ein Entwurf zur Pruefung durch den Nutzer\") }},\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\n        \"Schreibe eine Antwort auf diese Email.\\n\\n\" +\n        \"=== ANALYSE-ERGEBNIS ===\\n\" +\n        \"Tonalitaet: \" + $json.tonalitaet + \"\\n\" +\n        \"Dringlichkeit: \" + $json.dringlichkeit + \"\\n\" +\n        \"Stimmung: \" + $json.stimmung + \"\\n\" +\n        \"Empathie-Level: \" + $json.empathie_level + \"\\n\" +\n        \"Hauptanliegen: \" + $json.hauptanliegen + \"\\n\" +\n        \"Empfohlene Laenge: \" + $json.empfohlene_laenge + \" Woerter (+/-10%)\\n\" +\n        \"Antwort-Struktur: \" + $json.antwort_struktur + \"\\n\\n\" +\n        \"=== ORIGINAL-EMAIL ===\\n\" +\n        \"Absender: \" + $json.from_name + \" <\" + $json.from_email + \">\\n\" +\n        \"Kundenname (HubSpot): \" + $json.hubspot_name + \"\\n\" +\n        \"Firma: \" + ($json.hubspot_company || 'unbekannt') + \"\\n\" +\n        \"Betreff: \" + $json.subject + \"\\n\" +\n        \"Inhalt:\\n\" + $json.body + \"\\n\\n\" +\n        \"Erstelle den Email-Entwurf jetzt. Beginne direkt mit der Anrede.\"\n      ) }}\n    }\n  ]\n}",
        "options": {
          "timeout": 60000
        }
      },
